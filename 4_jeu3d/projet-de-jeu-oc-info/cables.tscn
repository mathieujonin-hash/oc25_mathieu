[sub_resource type="Shader" id="Shader_13hlb"]
code = "shader_type spatial;

uniform float speed = 0.7;
uniform float emission_strength = 4.0;
uniform float custom_time = 0.0;

void fragment() {
    vec2 uv = UV;

    float t = fract(custom_time * speed);

    float d = abs(uv.y - t);

    float pulse = exp(-d * 30.0);

    vec3 color = vec3(0.0, 0.0, 0.4) * pulse;

    ALBEDO = color;
    EMISSION = color * emission_strength;
}"

